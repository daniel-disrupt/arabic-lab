# Copy to .env for local development: `cp .env.example .env`. On Railway, set these as the
# service's environment variables instead — never commit a real .env.

# Postgres connection string. Railway's Postgres plugin provides this automatically as
# ${{Postgres.DATABASE_URL}} if you reference it in the service's variables.
DATABASE_URL=postgres://user:password@localhost:5432/arabic_lab_cms

# Single-admin Basic Auth credentials for the whole CMS.
ADMIN_USER=admin
ADMIN_PASS=change-me

# Where this service keeps its persistent state: uploaded media (uploads/) and its working
# copy of the public site's git repo (repo/). MUST be a Railway Volume mount path in
# production -- Railway's container filesystem is otherwise ephemeral and this data would
# vanish on every redeploy.
DATA_DIR=./.data

# The public site's repo, with a GitHub PAT embedded for push access:
#   https://<PAT>@github.com/daniel-disrupt/arabic-lab.git
# See README.md for how to mint a fine-grained token scoped to just this repo.
REPO_URL=

GIT_USER_NAME=Arabic Lab CMS
GIT_USER_EMAIL=cms@arabiclab.local

PORT=3000
